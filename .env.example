# ============================================================
# ARCGIS — Fill these in from your ArcGIS Online account
# ============================================================
ARCGIS_API_KEY=your_arcgis_api_key_here
ARCGIS_ORG_ID=your_org_id_here

# Feature Service root URL (from Step B above)
ARCGIS_FEATURE_SERVICE_URL=https://services.arcgis.com/YOUR_ORG_ID/arcgis/rest/services/MasterplanVelo/FeatureServer

# Layer indexes within the Feature Service
ARCGIS_LANES_LAYER=0
ARCGIS_PARKING_LAYER=1

# Writable Issues layer (from Step C above)
ARCGIS_ISSUES_LAYER_URL=https://services.arcgis.com/YOUR_ORG_ID/arcgis/rest/services/VeloIssues/FeatureServer/0

# ArcGIS Dashboard URL (from Step D above)
ARCGIS_DASHBOARD_URL=https://www.arcgis.com/apps/dashboards/YOUR_DASHBOARD_ID

# ============================================================
# BACKEND
# ============================================================
API_PORT=8000
SECRET_KEY=hackathon_secret_change_me

# ============================================================
# AI ENGINE
# ============================================================
AI_ENGINE_PORT=8001

# ============================================================
# FRONTEND (consumed by React apps via REACT_APP_ prefix)
# ============================================================
REACT_APP_ARCGIS_API_KEY=your_arcgis_api_key_here
REACT_APP_ARCGIS_FEATURE_SERVICE_URL=https://services.arcgis.com/YOUR_ORG_ID/arcgis/rest/services/MasterplanVelo/FeatureServer
REACT_APP_ARCGIS_ISSUES_LAYER_URL=https://services.arcgis.com/YOUR_ORG_ID/arcgis/rest/services/VeloIssues/FeatureServer/0
REACT_APP_ARCGIS_DASHBOARD_URL=https://www.arcgis.com/apps/dashboards/YOUR_DASHBOARD_ID
REACT_APP_API_URL=http://localhost:8000
