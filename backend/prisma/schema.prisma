generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================
// Enums
// ============================

enum UserRole {
  cetatean
  admin
}

enum ReportCategory {
  masini_parcate
  gropi
  constructii
  drum_blocat
  interferenta_pietoni
  obstacole
  parcari_biciclete
  iluminat
  altele
}

enum ReportSeverity {
  scazut
  mediu
  ridicat
  critic
}

enum ReportStatus {
  trimis
  in_analiza
  in_lucru
  rezolvat
  respins
}

enum ProposalCategory {
  pista_noua
  parcare_biciclete
  siguranta
  semaforizare
  infrastructura_verde
  altele
}

enum ProposalStatus {
  in_analiza
  aprobat
  respins
  in_implementare
}

enum ProjectStage {
  planificat
  proiectare
  simulare
  testare
  consultare_publica
  aprobare
  in_lucru
  finalizat
}

enum InfrastructureType {
  pista_biciclete
  parcare_biciclete
  semafor
  zona_30
  zona_pietonala
}

enum NotificationType {
  report_update
  proposal_vote
  project_update
  badge_earned
  system
}

enum ActivityType {
  report
  proposal
  vote
  comment
  badge
}

// ============================
// Models
// ============================

// Users — lightweight registration: only nickname required.
// Citizens can browse & report anonymously; auth needed only for comments/votes/likes.
model User {
  id           String   @id @default(cuid())
  nickname     String
  email        String?  @unique
  password     String?
  role         UserRole @default(cetatean)
  avatar       String?
  neighborhood String?
  sessionToken String   @unique @default(cuid())
  xp           Int      @default(0)
  level        Int      @default(1)
  levelName    String   @default("Începător")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  badges         UserBadge[]
  reports        Report[]
  proposals      Proposal[]
  comments       Comment[]
  votes          ProposalVote[]
  notifications  Notification[]
  projectFollows ProjectFollow[]
  projectLikes   ProjectLike[]
  activities     Activity[]

  @@map("users")
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String
  createdAt   DateTime    @default(now())

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// Reports — userId is optional so anonymous citizens can submit without registering
model Report {
  id            String         @id @default(cuid())
  userId        String?
  category      ReportCategory
  categoryLabel String
  severity      ReportSeverity
  status        ReportStatus   @default(trimis)
  title         String
  description   String
  latitude      Float
  longitude     Float
  address       String
  seenCount     Int            @default(1)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user   User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  photos ReportPhoto[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([latitude, longitude])
  @@map("reports")
}

model ReportPhoto {
  id        String   @id @default(cuid())
  reportId  String
  url       String
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("report_photos")
}

model Proposal {
  id            String           @id @default(cuid())
  userId        String
  category      ProposalCategory
  categoryLabel String
  title         String
  description   String
  latitude      Float
  longitude     Float
  address       String
  geometry      Json?            // GeoJSON geometry drawn by citizen
  status        ProposalStatus   @default(in_analiza)
  anonymousVoteScore Int         @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]
  votes    ProposalVote[]
  images   ProposalImage[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@map("proposals")
}

model ProposalImage {
  id         String   @id @default(cuid())
  proposalId String
  url        String
  createdAt  DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@map("proposal_images")
}

model ProposalVote {
  id         String   @id @default(cuid())
  userId     String
  proposalId String
  direction  Int      // 1 = up, -1 = down
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@unique([userId, proposalId])
  @@map("proposal_votes")
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  proposalId String?
  projectId  String?
  parentId   String?
  content    String
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposal Proposal? @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@index([proposalId])
  @@index([projectId])
  @@index([parentId])
  @@map("comments")
}

enum ProjectType {
  pista_biciclete
  parcare_biciclete
  semaforizare
  zona_30
  zona_pietonala
  coridor_verde
  infrastructura_mixta
}

model Project {
  id                     String       @id @default(cuid())
  title                  String
  description            String
  image                  String?
  stage                  ProjectStage @default(planificat)
  stageLabel             String
  projectType            ProjectType  @default(infrastructura_mixta)
  budget                 String?
  timeline               String
  team                   String?
  startDate              DateTime?
  endDate                DateTime?
  workingHours           String?      // e.g. "Luni-Vineri 07:00-19:00"
  latitude               Float
  longitude              Float
  address                String
  geometry               Json?        // GeoJSON FeatureCollection describing proposed changes
  simulationResults      Json?        // Snapshot of simulation metrics at time of export
  connectedRouteIds      String[]     @default([])
  citizenEngagementScore Int          @default(0)
  anonymousLikes         Int          @default(0)
  proposalId             String?      // Source proposal if converted
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  comments    Comment[]
  followers   ProjectFollow[]
  likes       ProjectLike[]
  simulations SimulationScenario[]

  @@index([stage])
  @@map("projects")
}

model ProjectFollow {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_follows")
}

model ProjectLike {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_likes")
}

model InfrastructureLayer {
  id               String  @id @default(cuid())
  type             String  @unique
  label            String
  color            String
  icon             String
  isDefaultVisible Boolean @default(false)
  createdAt        DateTime @default(now())

  elements InfrastructureElement[]

  @@map("infrastructure_layers")
}

model InfrastructureElement {
  id         String             @id @default(cuid())
  layerId    String
  type       InfrastructureType
  typeLabel  String
  name       String
  geometry   Json               // GeoJSON geometry
  properties Json               @default("{}")
  projectId  String?            // Associated project
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  layer InfrastructureLayer @relation(fields: [layerId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([layerId])
  @@index([projectId])
  @@map("infrastructure_elements")
}

model SimulationScenario {
  id                 String   @id @default(cuid())
  name               String
  description        String
  changes            Json?    // GeoJSON FeatureCollection of proposed changes
  safetyScore        Int
  coveragePercent    Int
  conflictZones      Int
  accessibilityScore Int
  projectId          String?  // Associated project
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("simulation_scenarios")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model Activity {
  id          String       @id @default(cuid())
  userId      String
  type        ActivityType
  description String
  link        String?
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("activities")
}

// ============================
// Transit / GTFS Models
// ============================

model TransitStop {
  id        String  @id
  name      String
  latitude  Float
  longitude Float
  type      Int     @default(0)  // 0=stop, 1=station
  parentId  String?

  @@index([latitude, longitude])
  @@map("transit_stops")
}

model TransitRoute {
  id        String @id
  shortName String
  longName  String @default("")
  type      Int    // 0=tram, 1=metro, 3=bus, 11=trolleybus
  color     String @default("")
  agencyId  String @default("")

  shapes TransitShape[]

  @@map("transit_routes")
}

model TransitShape {
  id       String @id @default(cuid())
  shapeId  String
  routeId  String?
  geometry Json   // GeoJSON LineString

  route TransitRoute? @relation(fields: [routeId], references: [id], onDelete: SetNull)

  @@index([shapeId])
  @@index([routeId])
  @@map("transit_shapes")
}

// ============================
// Road Network Graph
// ============================

model RoadNode {
  id        String @id @default(cuid())
  latitude  Float
  longitude Float
  name      String @default("")

  @@index([latitude, longitude])
  @@map("road_nodes")
}

model RoadSegment {
  id          String @id @default(cuid())
  fromNodeId  String
  toNodeId    String
  name        String @default("")
  length      Float  // meters
  roadType    String @default("car_only") // car_only | shared | bike_lane | pedestrian
  speedLimit  Int    @default(50)
  trafficLoad Float  @default(0) // 0-1 estimated load
  safetyScore Float  @default(50) // 0-100
  geometry    Json?  // GeoJSON LineString

  @@index([fromNodeId])
  @@index([toNodeId])
  @@map("road_segments")
}
